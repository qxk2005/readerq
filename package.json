{
  "name": "readerq",
  "version": "1.0.49",
  "description": "ReaderQ - 智能阅读助手",
  "author": "ReaderQ Team",
  "private": true,
  "bin": {
    "readerq": "./bin/readerq.js"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently -k \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && node scripts/build-electron.js && electron-builder && node scripts/post-build.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.readerq.app",
    "productName": "ReaderQ",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*"
    ],
    "asarUnpack": [
      ".next/standalone/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 270,
          "y": 350,
          "type": "file",
          "path": "改变权限.command"
        }
      ]
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "openai": "^6.44.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.2"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "fs-extra": "^11.3.5",
    "wait-on": "^9.0.10"
  }
}
